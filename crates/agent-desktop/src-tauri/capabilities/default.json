{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Core capability for local Tauri content, including the development URL",
  "local": true,
  "windows": ["main"],
  "permissions": [
    "core:default",
    "allow-desktop-shell-state",
    "allow-desktop-action",
    "allow-desktop-wsl-distributions",
    "allow-desktop-wsl-probe",
    "allow-desktop-wsl-prepare",
    "allow-desktop-wsl-connect",
    "allow-desktop-remote-request",
    "allow-desktop-remote-subscribe",
    "allow-desktop-remote-unsubscribe"
  ]
}
