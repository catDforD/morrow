{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Morrow",
  "version": "0.3.0",
  "identifier": "io.github.catdford.morrow",
  "build": {
    "beforeDevCommand": "pnpm --dir ../agent-server/web dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "pnpm --dir ../agent-server/web build",
    "frontendDist": "../../agent-server/assets"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
